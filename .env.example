# Production/staging should set DATABASE_URL to PostgreSQL.
# Local development can omit DATABASE_URL and use instance/andon_local.sqlite3.
DATABASE_URL="postgresql+psycopg://andon_user:change_this_password@localhost:5432/andon_db"
LOCAL_SQLITE_FALLBACK="true"
LOCAL_SQLITE_PATH="instance/andon_local.sqlite3"
PRESS_RADIUS_DATABASE_URL="postgresql+psycopg://radius_user:change_this_password@localhost:5432/press_radius_db"
SECRET_KEY="change-this-secret"
FLASK_CONFIG="production"
SOCKETIO_ENABLED="true"
ANDON_RUNTIME_SCHEMA_REPAIR="false"
PREFERENCE_PAYLOAD_MAX_BYTES="16384"
LOGIN_RATE_LIMIT_WINDOW_SECONDS="300"
LOGIN_RATE_LIMIT_MAX_ATTEMPTS="8"
SESSION_COOKIE_SECURE="true"
SESSION_COOKIE_SAMESITE="Lax"
SOCKETIO_ASYNC_MODE="threading"
SOCKETIO_FORCE_POLLING="false"
SOCKETIO_PING_INTERVAL="25"
SOCKETIO_PING_TIMEOUT="20"
HOST="0.0.0.0"
PORT="5001"

# Local Redis on Windows with Docker:
#   docker run --name andon-redis -p 6379:6379 -d redis:7-alpine
#   docker exec -it andon-redis redis-cli ping
# Keep REDIS_REQUIRED=false for local dev so the app still runs if Redis is stopped.
REDIS_URL="redis://127.0.0.1:6379/0"
REDIS_REQUIRED="false"
SOCKETIO_MESSAGE_QUEUE="redis://127.0.0.1:6379/0"
SOCKETIO_ALLOW_MULTIWORKER="false"

# Escalation email notifications
# Warning escalation sends to Viewer users scoped to the alert's machine group + department.
# Critical escalation sends to Manager users scoped to the alert's machine group (department ignored).
# Manual users below are always added as additional recipients.
ESCALATION_EMAIL_ENABLED="false"
ESCALATION_EMAIL_SMTP_HOST="smtp.your-provider.com"
ESCALATION_EMAIL_SMTP_PORT="587"
ESCALATION_EMAIL_SMTP_USER="alerts@your-company.com"
ESCALATION_EMAIL_SMTP_PASSWORD="change-me"
ESCALATION_EMAIL_FROM="alerts@your-company.com"
ESCALATION_EMAIL_USE_TLS="true"
ESCALATION_EMAIL_USE_SSL="false"

# Manual escalation users managed in code/env (not admin UI)
ESCALATION_MANUAL_USER_1_NAME="Escalation User 1"
ESCALATION_MANUAL_USER_1_EMAIL="escalation1@your-company.com"
ESCALATION_MANUAL_USER_2_NAME="Escalation User 2"
ESCALATION_MANUAL_USER_2_EMAIL="escalation2@your-company.com"
ESCALATION_MANUAL_USER_3_NAME="Escalation User 3"
ESCALATION_MANUAL_USER_3_EMAIL="escalation3@your-company.com"
ESCALATION_MANUAL_USER_4_NAME="Escalation User 4"
ESCALATION_MANUAL_USER_4_EMAIL="escalation4@your-company.com"
ESCALATION_MANUAL_USER_5_NAME="Escalation User 5"
ESCALATION_MANUAL_USER_5_EMAIL="escalation5@your-company.com"

# Production Redis:
# Set REDIS_REQUIRED=true and point both values at the production Redis instance.
# REDIS_URL="redis://redis-host:6379/0"
# REDIS_REQUIRED="true"
# SOCKETIO_MESSAGE_QUEUE="${REDIS_URL}"
# SOCKETIO_ASYNC_MODE="gevent"
# SOCKETIO_ALLOW_MULTIWORKER="true"
