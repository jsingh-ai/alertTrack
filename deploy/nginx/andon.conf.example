upstream andon_app {
    server 127.0.0.1:8000;
    keepalive 32;
}

server {
    listen 80;
    server_name andon.example.com;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    server_name andon.example.com;

    ssl_certificate /etc/letsencrypt/live/andon.example.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/andon.example.com/privkey.pem;

    client_max_body_size 10m;

    # This header is required when HTTPS terminates at Nginx. Flask must see the
    # forwarded scheme as https so secure session cookies and login CSRF flows work.
    proxy_set_header Host $host;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_set_header X-Forwarded-Host $host;
    proxy_set_header X-Forwarded-Port $server_port;

    location /socket.io/ {
        proxy_pass http://andon_app;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_read_timeout 75s;
        proxy_send_timeout 75s;
    }

    location / {
        proxy_pass http://andon_app;
        proxy_http_version 1.1;
        proxy_read_timeout 60s;
        proxy_send_timeout 60s;
    }
}
